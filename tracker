<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>極簡記帳 LazyTracker v2</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        [v-cloak] { display: none; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen p-4 pb-12">
    <div id="app" v-cloak class="max-w-md mx-auto">
        
        <header class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">LazyTracker</h1>
            <div class="space-x-2">
                <button @click="exportToCSV" class="text-[10px] bg-gray-200 px-2 py-1 rounded text-gray-600">匯出</button>
                <button @click="triggerImport" class="text-[10px] bg-blue-100 px-2 py-1 rounded text-blue-600">匯入</button>
                <input type="file" ref="fileInput" @change="handleImport" accept=".csv" class="hidden">
            </div>
        </header>

        <div class="bg-white rounded-2xl shadow-sm p-6 mb-6 border border-gray-100">
            <div class="space-y-4">
                <div>
                    <label class="block text-xs text-gray-400 mb-1">金額 (可輸入 10*50)</label>
                    <input type="text" v-model="entry.rawAmount" @blur="calcAmount" 
                           placeholder="0.00"
                           class="w-full text-3xl font-semibold border-b-2 border-gray-100 focus:border-blue-500 outline-none pb-2">
                </div>

                <div>
                    <label class="block text-xs text-gray-400 mb-2">Tags (多選)</label>
                    <div class="flex flex-wrap gap-2">
                        <button v-for="tag in availableTags" :key="tag"
                                @click="toggleTag(tag)"
                                :class="entry.tags.includes(tag) ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600'"
                                class="px-3 py-1.5 rounded-full text-sm transition-all active:scale-95">
                            {{ tag }}
                        </button>
                    </div>
                </div>

                <details class="group">
                    <summary class="text-sm text-blue-500 cursor-pointer list-none flex items-center py-2">
                        <span class="mr-1">詳細資料 (Optional)</span>
                        <svg class="w-4 h-4 transition group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                    </summary>
                    <div class="pt-2 space-y-4">
                        <div>
                            <label class="block text-xs text-gray-400 mb-2">支付方式 / 信用卡</label>
                            <div class="grid grid-cols-3 gap-2">
                                <button v-for="card in ['Cash', ...cards, 'PayPal']" 
                                        @click="entry.payment = card"
                                        :class="entry.payment === card ? 'border-blue-500 bg-blue-50 text-blue-600' : 'border-gray-100 bg-gray-50 text-gray-500'"
                                        class="py-2 text-[10px] rounded-lg border">
                                    {{ card }}
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-400 mb-2">物流狀態</label>
                            <div class="flex gap-2">
                                <button v-for="s in ['Pending', 'Delivered', '已取']" 
                                        @click="entry.status = s"
                                        :class="entry.status === s ? 'ring-2 ring-blue-400 bg-blue-50' : 'bg-gray-50'"
                                        class="flex-1 py-2 text-xs rounded-lg border border-gray-100 text-gray-500">
                                    {{ s }}
                                </button>
                            </div>
                        </div>
                    </div>
                </details>

                <button @click="saveEntry" 
                        class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold shadow-lg active:scale-95 transition-transform">
                    儲存紀錄
                </button>
            </div>
        </div>

        <div class="space-y-3">
            <h2 class="text-gray-500 text-sm font-medium px-1 flex justify-between">
                <span>最近紀錄</span>
                <span @click="clearAll" class="text-[10px] text-red-300 cursor-pointer">清空全部</span>
            </h2>
            <div v-for="(item, index) in history" :key="index" 
                 class="bg-white p-4 rounded-xl shadow-sm border border-gray-50 flex justify-between items-center">
                <div class="flex-1">
                    <div class="flex flex-wrap gap-1 mb-1">
                        <span v-for="t in item.tags" class="text-[10px] bg-blue-50 text-blue-500 px-2 py-0.5 rounded-md">{{ t }}</span>
                    </div>
                    <div class="text-[11px] text-gray-400 font-light">
                        {{ item.date }} · {{ item.payment }} · <span :class="item.status === 'Pending' ? 'text-orange-400' : ''">{{ item.status }}</span>
                    </div>
                </div>
                <div class="text-right ml-4 font-bold text-gray-800 text-lg">${{ item.amount }}</div>
            </div>
        </div>
    </div>

    <script>
        const { createApp, ref } = Vue;

        createApp({
            setup() {
                const fileInput = ref(null);
                const cards = ['MOX', 'HSBC', 'SC', 'DBS'];
                const availableTags = ['日常', '交際', '慶生', '追星', 'Travel', 'Sub'];
                
                const entry = ref({ rawAmount: '', amount: 0, tags: [], payment: 'Cash', status: 'Delivered' });
                const history = ref(JSON.parse(localStorage.getItem('lazy_records') || '[]'));

                const calcAmount = () => {
                    try {
                        let val = entry.value.rawAmount.replace(/[^-()\d/*+.]/g, '');
                        entry.value.amount = eval(val) || 0;
                    } catch { entry.value.amount = parseFloat(entry.value.rawAmount) || 0; }
                };

                const toggleTag = (tag) => {
                    const i = entry.value.tags.indexOf(tag);
                    if (i > -1) entry.value.tags.splice(i, 1);
                    else entry.value.tags.push(tag);
                };

                const saveEntry = () => {
                    calcAmount();
                    if (!entry.value.amount) return alert('入錢先！');
                    const newRecord = { ...entry.value, date: new Date().toLocaleDateString() };
                    history.value.unshift(newRecord);
                    localStorage.setItem('lazy_records', JSON.stringify(history.value));
                    entry.value.rawAmount = ''; entry.value.tags = [];
                };

                const exportToCSV = () => {
                    let csv = "\uFEFFDate,Amount,Tags,Payment,Status\n";
                    history.value.forEach(r => {
                        csv += `${r.date},${r.amount},"${r.tags.join('|')}",${r.payment},${r.status}\n`;
                    });
                    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement("a");
                    link.href = url;
                    link.download = `LazyTracker_${new Date().toLocaleDateString()}.csv`;
                    link.click();
                };

                const triggerImport = () => fileInput.value.click();

                const handleImport = (event) => {
                    const file = event.target.files[0];
                    if (!file) return;
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const content = e.target.result;
                        const rows = content.split("\n").slice(1);
                        const importedData = rows.filter(row => row.trim() !== "").map(row => {
                            const cols = row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
                            return {
                                date: cols[0],
                                amount: parseFloat(cols[1]),
                                tags: cols[2].replace(/"/g, '').split('|').filter(t => t !== ""),
                                payment: cols[3],
                                status: cols[4]
                            };
                        });
                        if (confirm(`確認匯入 ${importedData.length} 條紀錄？這將與現有紀錄合併。`)) {
                            history.value = [...importedData, ...history.value];
                            localStorage.setItem('lazy_records', JSON.stringify(history.value));
                        }
                    };
                    reader.readAsText(file);
                };

                const clearAll = () => {
                    if(confirm("確定清空所有紀錄？建議先匯出備份！")) {
                        history.value = [];
                        localStorage.removeItem('lazy_records');
                    }
                }

                return { fileInput, cards, availableTags, entry, history, toggleTag, saveEntry, calcAmount, exportToCSV, triggerImport, handleImport, clearAll };
            }
        }).mount('#app');
    </script>
</body>
</html>
